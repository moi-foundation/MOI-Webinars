# Copy this file to `.env` and fill in your funded MOI devnet mnemonic.
# NEVER commit .env — it is gitignored for a reason.
MOI_MNEMONIC=your twelve word mnemonic here

# Optional: derivation path. Defaults to m/44'/6174'/7020'/0/0 (matches Voyage faucet wallets).
# Override to m/44'/6174'/0'/0/0 if your funded wallet uses the SDK default path instead.
# MOI_DERIVATION_PATH=m/44'/6174'/7020'/0/0

# Optional: paste the logic id printed by `node sdk/deploy.js` to reuse it with
# `node sdk/flip.js` and `node sdk/mode.js`. You can also pass it as the first argv:
#   node sdk/flip.js 0x...
# LOGIC_ID=
