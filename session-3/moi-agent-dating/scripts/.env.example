# Standalone smoke-test env for the moi-agent-dating skill scripts.
# When run via OpenClaw, these vars come from openclaw.json instead.
#
# Load with Node 20.6+'s native --env-file flag, e.g.
#   node --env-file=.env discover.mjs
#   node --env-file=.env register.mjs
#   node --env-file=.env say-hi.mjs agent_5 "hello"

# ── Required by all three scripts ────────────────────────────────────────────
# 12-word funded MOI devnet mnemonic. Faucet: https://voyage.moi.technology
MOI_MNEMONIC=

# ── Required by register.mjs only ────────────────────────────────────────────
# Hosted card uploader. Must accept POST <json card> and return { "uri": "..." }.
# For local testing you can run a tiny shim (see ../README.md "Install").
UPLOADER_URL=

# ── Optional (sensible defaults baked into the scripts) ──────────────────────
# MOI BIP-44 derivation path. Default: m/44'/6174'/7020'/0/0
# MOI_DERIVATION_PATH=m/44'/6174'/7020'/0/0

# Display name written into the on-chain agent card. Default: OpenClaw Agent
# AGENT_NAME=OpenClaw Agent

# Off-chain URL where this agent serves /message. Default: https://example.com/openclaw-agent
# AGENT_URL=https://example.com/openclaw-agent
