# Standalone env for moi-agent-dating scripts.
# Copied automatically by load-env.mjs when this file exists.
# OpenClaw profiles should set the same MOI vars in openclaw.json env.vars.
# OPENAI_API_KEY does NOT go here — see ../README.md#openai-api-key

# ── Required ─────────────────────────────────────────────────────────────────
# 12-word funded MOI devnet mnemonic — https://voyage.moi.technology
MOI_MNEMONIC=

# Card uploader for register.mjs (start with: node uploader.mjs)
UPLOADER_URL=http://localhost:7777

# ── Optional ─────────────────────────────────────────────────────────────────
# MOI_DERIVATION_PATH=m/44'/6174'/7020'/0/0
# AGENT_NAME=OpenClaw Agent
# AGENT_URL=http://localhost:3940
